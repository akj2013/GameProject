# Project documents & art source (내가 만든 자료는 포함)
!/ArtSource/

# Asset Store / third-party and general Assets control
# 기본적으로 Assets 전체를 무시하고, 내가 만든/프로젝트 전용 폴더만 예외로 허용
/Assets/*

#! 프로젝트 전용/직접 만든 폴더들
!/Assets/Docs/
!/Assets/MyPrefab/
!/Assets/MyScenes/
!/Assets/MyScript/
!/Assets/Resources/
!/Assets/Settings/
!/Assets/Editor/

#! 루트에 있는 프로젝트 설정/리드미 자산
!/Assets/DefaultVolumeProfile.asset
!/Assets/DefaultVolumeProfile.asset.meta
!/Assets/InputSystem_Actions.inputactions
!/Assets/InputSystem_Actions.inputactions.meta
!/Assets/Readme.asset
!/Assets/Readme.asset.meta

#! 서드파티/툴/스크린샷/사운드 등은 계속 무시
/Assets/MCPForUnity/
/Assets/TextMesh Pro/
/Assets/Screenshots/
/Assets/TextMesh Pro.meta
/Assets/UnusedAssets*
/Assets/Resources/SOUND/
